{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd neullmfront && npm install",
  "buildCommand": "cd neullmfront && npm run build",
  "outputDirectory": "neullmfront/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://neullm-production.up.railway.app/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
